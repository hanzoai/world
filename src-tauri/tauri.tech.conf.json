{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hanzo Tech",
  "mainBinaryName": "hanzo-tech",
  "identifier": "ai.hanzo.world.tech.desktop",
  "app": {
    "windows": [
      {
        "title": "Hanzo Tech"
      }
    ]
  },
  "bundle": {
    "shortDescription": "Hanzo Tech desktop app",
    "longDescription": "Hanzo Tech desktop app for real-time AI and technology intelligence.",
    "targets": [
      "app",
      "dmg",
      "nsis",
      "msi",
      "appimage"
    ],
    "macOS": {
      "hardenedRuntime": true
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": true
      }
    },
    "windows": {
      "digestAlgorithm": "sha256",
      "timestampUrl": "https://timestamp.digicert.com",
      "nsis": {
        "installerHooks": "nsis/installer-hooks.nsh"
      }
    }
  }
}
