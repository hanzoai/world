# Cloudflare Pages headers (replaces vercel.json headers block).

/*
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(self), accelerometer=(), bluetooth=(), display-capture=(), gyroscope=(), hid=(), idle-detection=(), magnetometer=(), midi=(), payment=(self "https://pay.google.com"), picture-in-picture=(self "https://www.youtube.com" "https://www.youtube-nocookie.com"), screen-wake-lock=(), serial=(), usb=(), xr-spatial-tracking=()
  Content-Security-Policy: default-src 'self'; connect-src 'self' https: wss: blob: data: https://*.ingest.sentry.io https://*.ingest.us.sentry.io https://hanzo.id https://api.hanzo.ai; img-src 'self' data: blob: https:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; script-src 'self' 'wasm-unsafe-eval' https://www.youtube.com https://static.cloudflareinsights.com https://challenges.cloudflare.com https://abacus.world.hanzo.ai; worker-src 'self' blob:; font-src 'self' data: https:; media-src 'self' data: blob: https:; frame-src 'self' https://world.hanzo.ai https://hanzo.id https://www.youtube.com https://www.youtube-nocookie.com https://challenges.cloudflare.com; frame-ancestors 'self' https://world.hanzo.ai; base-uri 'self'; object-src 'none'; form-action 'self' https://api.hanzo.ai https://hanzo.id

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/blog/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/map-styles/*
  Cache-Control: public, max-age=31536000, immutable

/data/*
  Cache-Control: public, max-age=31536000, immutable

/textures/*
  Cache-Control: public, max-age=31536000, immutable

/index.html
  Cache-Control: private, no-cache, must-revalidate

/sw.js
  Cache-Control: public, max-age=0, must-revalidate

/manifest.webmanifest
  Cache-Control: public, max-age=86400

/offline.html
  Cache-Control: public, max-age=86400
