    },
    "description": {
      "type": "string"
    },
    "metaTitle": {
      "type": "string"
    },
    "keywords": {
      "type": "string"
    },
    "audience": {
      "type": "string"
    },
    "pubDate": {
      "type": "string",
      "format": "date-time"
    },
    "modifiedDate": {
      "type": "string",
